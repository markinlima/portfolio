{
  "name": "react-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run script:create-images-type && vite dev --mode dev",
    "build": "vite build",
    "serve": "vite preview",
    "format": "biome format --write",
    "lint": "tsc --noEmit && biome lint",
    "check": "biome check",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project storybook",
    "test:ci": "bun run test:integration",
    "script:create-route-tree": "tsr generate",
    "script:generate-types": "bun run script:create-images-type && bun run script:create-route-tree",
    "script:create-images-type": "bun ./scripts/create-images-type.ts",
    "script:optimize-images": "bun ./scripts/optimize-images.ts && bun run script:create-images-type",
    "storybook:dev": "storybook dev -p 6006",
    "storybook:build": "storybook build -o ./build/storybook",
    "docker:test": "docker compose -f ./docker/test/docker-compose.yml up --wait --wait-timeout 480 --build --remove-orphans && bun run docker:test-down",
    "docker:test-down": "docker compose -f ./docker/test/docker-compose.yml down -v",
    "docker:build": "docker compose -f ./docker/prod/docker-compose.yml up -d --build --remove-orphans",
    "docker:scan": "docker compose -f ./docker/prod/docker-compose.yml build && trivy image --format table --output ./build/trivy/scan-result.txt production-react-template-app"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-devtools": "^0.10.2",
    "@tanstack/react-form": "^1.29.1",
    "@tanstack/react-form-devtools": "^0.2.22",
    "@tanstack/react-query": "^5.100.5",
    "@tanstack/react-query-devtools": "^5.100.5",
    "@tanstack/react-router": "^1.168.24",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@tanstack/react-start": "^1.167.49",
    "@vitejs/plugin-react": "^6.0.1",
    "axios": "^1.15.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "dayjs": "^1.11.20",
    "discord.js": "^14.26.3",
    "immer": "^11.1.4",
    "lucide-react": "^1.11.0",
    "nitro": "^3.0.260415-beta",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-scan": "^0.5.3",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.4",
    "tailwindcss-motion": "^1.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@chromatic-com/storybook": "^5.1.2",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-onboarding": "^10.3.5",
    "@storybook/addon-themes": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@tanstack/router-cli": "^1.166.36",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "consola": "^3.4.2",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "storybook": "^10.3.5",
    "storybook-addon-tag-badges": "^3.1.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
